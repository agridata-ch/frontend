{
  "name": "frontend",
  "version": "1.14.0-rc.4",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test:unit": "jest",
    "test:coverage": "jest --coverage --no-cache",
    "test:watch": "jest --watch",
    "cm": "cz",
    "prettier:staged": "npx pretty-quick --staged --restage",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "typecheck": "tsc --build --noEmit",
    "i18n:extract": "transloco-keys-manager extract",
    "i18n:find": "transloco-keys-manager find",
    "i18n:sync": "./src/scripts/sync-translations.sh",
    "i18n:sync:windows": "powershell -ExecutionPolicy Bypass -File \"src/scripts/sync_translations.ps1\" ",
    "commentcheck": "./src/scripts/check-comments.sh",
    "preinstall": "node -e \"require('dotenv').config()\"",
    "api:generate": "openapi-generator-cli generate -i src/assets/openapi.yaml -g typescript-angular -o ./src/entities/openapi --global-property=apis,models,supportingFiles --skip-validate-spec --enable-post-process-file --additional-properties=supportsES6=true --ignore-file-override=./scripts/openapi-ignore.txt",
    "api:fetch:dev": "curl -H \"User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36\" \"https://api.dev.agridata.ch/q/openapi\" -o src/assets/openapi.yaml",
    "api:fetch:local": "curl -H \"User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36\" \"http://localhost:8060/q/openapi\" -o src/assets/openapi.yaml",
    "api:sync:local": "npm run api:fetch:local && npm run api:generate",
    "api:sync:dev": "npm run api:fetch:dev && npm run api:generate",
    "sourcemap:analyze": "ng build --source-map && npx source-map-explorer dist/frontend/**/*.js --no-border-checks",
    "storybook": "ng run frontend:storybook",
    "build:storybook": "ng run frontend:build-storybook"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/platform-browser-dynamic": "22.0.2",
    "@angular/router": "22.0.2",
    "@awesome.me/kit-0b6d1ed528": "1.0.31",
    "@jsverse/transloco": "8.4.0",
    "driver.js": "1.5.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "22.0.1",
    "@angular-devkit/architect": "0.2200.4",
    "@angular-devkit/build-angular": "22.0.4",
    "@angular-devkit/core": "22.0.4",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.2",
    "@commitlint/config-conventional": "21.1.0",
    "@eslint/js": "10.0.1",
    "@feature-sliced/eslint-config": "0.1.1",
    "@fortawesome/angular-fontawesome": "3.0.0",
    "@openapitools/openapi-generator-cli": "2.39.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/angular": "10.4.6",
    "@tailwindcss/postcss": "4.3.1",
    "@types/jest": "30.0.0",
    "angular-auth-oidc-client": "21.0.2",
    "commitizen": "4.3.2",
    "commitlint": "21.1.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cz-conventional-changelog": "3.3.0",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "eslint": "10.5.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsdoc": "63.0.7",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-unicorn": "68.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-angular": "17.0.0",
    "marked": "18.0.5",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "pretty-quick": "4.2.2",
    "semantic-release": "25.0.5",
    "source-map-explorer": "2.5.3",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
