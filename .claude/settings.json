{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:unit)",
      "Bash(npm run test:coverage)",
      "Read(~/.zshrc)"
    ],
    "deny": ["Read(./.env.*)"],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "ti8m-improvement-claude-md@ti8m-claude-code-marketplace": true
  }
}
